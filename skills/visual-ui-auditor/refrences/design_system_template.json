{
    "_comment": "Replace this file with your actual design system spec. All fields are optional — only include what you want to audit against.",
    "brand": "My Company",
    "colors": {
      "primary": "#007bff",
      "primary_hover": "#0056b3",
      "secondary": "#6c757d",
      "success": "#28a745",
      "warning": "#ffc107",
      "error": "#dc3545",
      "background": "#ffffff",
      "surface": "#f8f9fa",
      "text_primary": "#212529",
      "text_secondary": "#6c757d",
      "border": "#dee2e6"
    },
    "typography": {
      "font_family_primary": "Inter, -apple-system, sans-serif",
      "font_family_mono": "Fira Code, monospace",
      "scale": {
        "h1": { "size_px": 32, "weight": 700, "line_height": 1.2 },
        "h2": { "size_px": 24, "weight": 700, "line_height": 1.3 },
        "h3": { "size_px": 20, "weight": 600, "line_height": 1.4 },
        "body": { "size_px": 16, "weight": 400, "line_height": 1.5 },
        "small": { "size_px": 14, "weight": 400, "line_height": 1.4 },
        "caption": { "size_px": 12, "weight": 400, "line_height": 1.3 }
      }
    },
    "spacing": {
      "base_unit_px": 8,
      "scale": [0, 4, 8, 12, 16, 24, 32, 48, 64],
      "_comment": "All margin/padding values should be multiples of base_unit_px"
    },
    "border_radius": {
      "sm": "4px",
      "md": "8px",
      "lg": "12px",
      "full": "9999px"
    },
    "shadows": {
      "sm": "0 1px 3px rgba(0,0,0,0.12)",
      "md": "0 4px 6px rgba(0,0,0,0.10)",
      "lg": "0 10px 15px rgba(0,0,0,0.10)"
    },
    "components": {
      "button_primary": {
        "background": "#007bff",
        "text_color": "#ffffff",
        "border_radius": "8px",
        "padding": "8px 16px",
        "font_weight": 600,
        "min_touch_target_px": 44
      },
      "button_secondary": {
        "background": "transparent",
        "border": "2px solid #007bff",
        "text_color": "#007bff",
        "border_radius": "8px",
        "padding": "8px 16px"
      },
      "input": {
        "border": "1px solid #dee2e6",
        "border_radius": "4px",
        "padding": "8px 12px",
        "focus_outline": "#007bff",
        "error_border": "#dc3545"
      },
      "modal": {
        "backdrop": "rgba(0,0,0,0.5)",
        "border_radius": "12px",
        "max_width_px": 600
      }
    },
    "dark_pattern_checks": {
      "check_confirm_shaming": true,
      "check_hidden_unsubscribe": true,
      "check_prechecked_optins": true,
      "check_misleading_hierarchy": true,
      "_comment": "Set any to false to skip that dark pattern check"
    }
  }